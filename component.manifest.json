{
  "$schema": "https://greentic-ai.github.io/greentic-component/schemas/v1/component.manifest.schema.json",
  "artifacts": {
    "component_wasm": "target/wasm32-wasip2/release/component_adaptive_card.wasm"
  },
  "capabilities": {
    "host": {
      "messaging": {
        "inbound": true,
        "outbound": true
      },
      "secrets": {
        "required": []
      },
      "state": {
        "delete": true,
        "read": true,
        "write": true
      },
      "telemetry": {
        "scope": "node"
      }
    },
    "wasi": {
      "clocks": true,
      "filesystem": {
        "mode": "read_only",
        "mounts": [
          {
            "guest_path": ".",
            "host_class": "cwd",
            "name": "workspace"
          }
        ]
      },
      "random": true
    }
  },
  "config_schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "component-adaptive-card component configuration",
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "default_source": {
        "type": "string",
        "enum": ["inline", "asset", "catalog"],
        "default": "inline",
        "description": "How cards should be loaded by default when an invocation does not override the source."
      },
      "default_card_inline": {
        "type": ["object", "array", "null"],
        "default": null,
        "description": "Default Adaptive Card JSON used when default_source is inline."
      },
      "default_card_asset": {
        "type": ["string", "null"],
        "default": null,
        "description": "Default card asset path or reference used when default_source is asset."
      },
      "catalog_registry_ref": {
        "type": ["string", "null"],
        "default": null,
        "description": "Catalog registry reference used when resolving catalog_name entries. Examples: store://greentic-biz/_/adaptive-cards/default or repo://my-repo/cards/catalog.json."
      },
      "multilingual": {
        "type": "boolean",
        "default": true,
        "description": "Whether localized rendering should use supported locales beyond English."
      },
      "language_mode": {
        "type": "string",
        "enum": ["all", "custom"],
        "default": "all",
        "description": "Whether to allow every built-in locale or a custom subset."
      },
      "supported_locales": {
        "type": ["array", "null"],
        "default": null,
        "items": {
          "type": "string"
        },
        "description": "Custom locale allow-list used when language_mode is custom. English remains implicit fallback behavior."
      },
      "direction_mode": {
        "type": "string",
        "enum": ["ltr", "rtl", "auto"],
        "default": "ltr",
        "description": "How the Adaptive Card root rtl flag should be emitted."
      },
      "validation_mode": {
        "type": "string",
        "enum": ["off", "warn", "error"],
        "default": "warn",
        "description": "Default invocation schema validation behavior."
      },
      "trace_enabled": {
        "type": "boolean",
        "default": false,
        "description": "Whether to emit adaptive-card trace telemetry by default."
      },
      "trace_capture_inputs": {
        "type": "boolean",
        "default": false,
        "description": "Whether traces may include payload, session, state, and interaction inputs."
      }
    }
  },
  "default_operation": "card",
  "describe_export": "describe",
  "dev_flows": {
    "custom": {
      "format": "flow-ir-json",
      "graph": {
        "description": "Setup config flow for ai.greentic.component-adaptive-card",
        "id": "ai.greentic.component-adaptive-card.custom",
        "kind": "component-config",
        "nodes": {
          "ask_config": {
            "questions": {
              "fields": [
                {
                  "id": "default_source",
                  "prompt": "How should cards be loaded by default?",
                  "type": "enum",
                  "options": ["inline", "asset", "catalog"],
                  "default": "inline"
                },
                {
                  "id": "default_card_inline",
                  "prompt": "Paste the default Adaptive Card JSON.",
                  "type": "string",
                  "show_if": { "id": "default_source", "equals": "inline" }
                },
                {
                  "id": "default_card_asset",
                  "prompt": "Enter the default card asset path/reference.",
                  "type": "string",
                  "show_if": { "id": "default_source", "equals": "asset" }
                },
                {
                  "id": "catalog_registry_ref",
                  "prompt": "Enter the card catalog reference. Examples: store://greentic-biz/_/adaptive-cards/default or repo://my-repo/cards/catalog.json",
                  "type": "string",
                  "show_if": { "id": "default_source", "equals": "catalog" }
                },
                {
                  "id": "multilingual",
                  "prompt": "Do you want to support multiple languages?",
                  "type": "boolean",
                  "default": true
                },
                {
                  "id": "language_mode",
                  "prompt": "Which languages do you want to support?",
                  "type": "enum",
                  "options": ["all", "custom"],
                  "default": "all",
                  "show_if": { "id": "multilingual", "equals": true }
                },
                {
                  "id": "supported_locales",
                  "prompt": "Enter a comma-separated list of locale codes, for example: en,fr,de",
                  "type": "string",
                  "show_if": { "id": "language_mode", "equals": "custom" }
                },
                {
                  "id": "direction_mode",
                  "prompt": "Text direction",
                  "type": "enum",
                  "options": ["ltr", "rtl", "auto"],
                  "default": "ltr"
                },
                {
                  "id": "validation_mode",
                  "prompt": "Validation mode",
                  "type": "enum",
                  "options": ["off", "warn", "error"],
                  "default": "warn"
                },
                {
                  "id": "trace_enabled",
                  "prompt": "Enable tracing?",
                  "type": "boolean",
                  "default": false
                },
                {
                  "id": "trace_capture_inputs",
                  "prompt": "Include inputs in traces?",
                  "type": "boolean",
                  "default": false,
                  "show_if": { "id": "trace_enabled", "equals": true }
                }
              ]
            },
            "routing": [
              {
                "to": "emit_config"
              }
            ]
          },
          "emit_config": {
            "template": "{\n  \"node_id\": \"component-adaptive-card\",\n  \"node\": {\n    \"tool\": {\n      \"component\": \"ai.greentic.component-adaptive-card\",\n      \"default_source\": {{json state.default_source}},\n      {{#ifEq state.default_source \"inline\"}}\n      \"default_card_inline\": {{json state.default_card_inline}},\n      {{/ifEq}}\n      {{#ifEq state.default_source \"asset\"}}\n      \"default_card_asset\": {{json state.default_card_asset}},\n      {{/ifEq}}\n      {{#ifEq state.default_source \"catalog\"}}\n      \"catalog_registry_ref\": {{json state.catalog_registry_ref}},\n      {{/ifEq}}\n      \"multilingual\": {{json state.multilingual}},\n      {{#if state.multilingual}}\n      \"language_mode\": {{json state.language_mode}},\n      {{#ifEq state.language_mode \"custom\"}}\n      \"supported_locales\": {{json state.supported_locales}},\n      {{/ifEq}}\n      {{/if}}\n      \"direction_mode\": {{json state.direction_mode}},\n      \"validation_mode\": {{json state.validation_mode}},\n      \"trace_enabled\": {{json state.trace_enabled}},\n      {{#if state.trace_enabled}}\n      \"trace_capture_inputs\": {{json state.trace_capture_inputs}}\n      {{else}}\n      \"trace_capture_inputs\": false\n      {{/if}}\n    },\n    \"routing\": [\n      { \"to\": \"NEXT_NODE_PLACEHOLDER\" },\n      { \"out\": true }\n    ]\n  }\n}"
          }
        }
      }
    },
    "default": {
      "format": "flow-ir-json",
      "graph": {
        "description": "Minimal config flow for ai.greentic.component-adaptive-card",
        "id": "ai.greentic.component-adaptive-card.default",
        "kind": "component-config",
        "nodes": {
          "ask_config": {
            "questions": {
              "fields": [
                {
                  "id": "default_source",
                  "prompt": "How should cards be loaded by default?",
                  "type": "enum",
                  "options": ["inline", "asset", "catalog"],
                  "default": "inline"
                },
                {
                  "id": "default_card_inline",
                  "prompt": "Paste the default Adaptive Card JSON.",
                  "type": "string",
                  "show_if": { "id": "default_source", "equals": "inline" }
                },
                {
                  "id": "default_card_asset",
                  "prompt": "Enter the default card asset path/reference.",
                  "type": "string",
                  "show_if": { "id": "default_source", "equals": "asset" }
                },
                {
                  "id": "catalog_registry_ref",
                  "prompt": "Enter the card catalog reference. Examples: store://greentic-biz/_/adaptive-cards/default or repo://my-repo/cards/catalog.json",
                  "type": "string",
                  "show_if": { "id": "default_source", "equals": "catalog" }
                },
                {
                  "id": "multilingual",
                  "prompt": "Do you want to support multiple languages?",
                  "type": "boolean",
                  "default": true
                },
                {
                  "id": "language_mode",
                  "prompt": "Which languages do you want to support?",
                  "type": "enum",
                  "options": ["all", "custom"],
                  "default": "all",
                  "show_if": { "id": "multilingual", "equals": true }
                },
                {
                  "id": "supported_locales",
                  "prompt": "Enter a comma-separated list of locale codes, for example: en,fr,de",
                  "type": "string",
                  "show_if": { "id": "language_mode", "equals": "custom" }
                }
              ]
            },
            "routing": [
              {
                "to": "emit_config"
              }
            ]
          },
          "emit_config": {
            "template": "{\n  \"node_id\": \"component-adaptive-card\",\n  \"node\": {\n    \"tool\": {\n      \"component\": \"ai.greentic.component-adaptive-card\",\n      \"default_source\": {{json state.default_source}},\n      {{#ifEq state.default_source \"inline\"}}\n      \"default_card_inline\": {{json state.default_card_inline}},\n      {{/ifEq}}\n      {{#ifEq state.default_source \"asset\"}}\n      \"default_card_asset\": {{json state.default_card_asset}},\n      {{/ifEq}}\n      {{#ifEq state.default_source \"catalog\"}}\n      \"catalog_registry_ref\": {{json state.catalog_registry_ref}},\n      {{/ifEq}}\n      \"multilingual\": {{json state.multilingual}},\n      {{#if state.multilingual}}\n      \"language_mode\": {{json state.language_mode}},\n      {{#ifEq state.language_mode \"custom\"}}\n      \"supported_locales\": {{json state.supported_locales}}\n      {{else}}\n      \"supported_locales\": null\n      {{/ifEq}}\n      {{else}}\n      \"language_mode\": \"all\",\n      \"supported_locales\": null\n      {{/if}},\n      \"direction_mode\": \"ltr\",\n      \"validation_mode\": \"warn\",\n      \"trace_enabled\": false,\n      \"trace_capture_inputs\": false\n    },\n    \"routing\": [\n      { \"to\": \"NEXT_NODE_PLACEHOLDER\" }\n    ]\n  }\n}"
          }
        }
      }
    }
  },
  "hashes": {
    "component_wasm": "blake3:eb077db67fe66be8a23d56f75b9715094bb6c53231cfd7ab8a85d9e2acf6fa2c"
  },
  "id": "ai.greentic.component-adaptive-card",
  "limits": {
    "memory_mb": 128,
    "wall_time_ms": 1000
  },
  "name": "component-adaptive-card",
  "operations": [
    {
      "name": "card",
      "input_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "title": "Adaptive Card invocation input",
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "envelope": {
            "description": "Optional Greentic invocation envelope metadata.",
            "type": "object"
          },
          "card_source": {
            "type": "string",
            "enum": ["inline", "asset", "catalog"],
            "default": "inline",
            "description": "Per-call override for where to load the card from."
          },
          "card_spec": {
            "type": "object",
            "description": "Per-call details for resolving the card source. When omitted, component config defaults may supply the card source details.",
            "properties": {
              "inline_json": {
                "type": ["object", "array"]
              },
              "asset_path": {
                "type": "string"
              },
              "catalog_name": {
                "type": "string",
                "description": "Catalog entry name to resolve through the configured catalog registry."
              },
              "template_params": {
                "type": ["object", "array"]
              },
              "asset_registry": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "description": "Optional inline mapping of asset or catalog names to concrete paths."
              }
            }
          },
          "node_id": {
            "type": "string",
            "description": "Optional node id used to scope persisted state and helper context."
          },
          "locale": {
            "type": "string",
            "description": "Preferred locale for this render. Overrides session and envelope locale when valid."
          },
          "i18n_locale": {
            "type": "string",
            "description": "Deprecated alias for locale retained for compatibility."
          },
          "payload": {
            "type": ["object", "array", "null"],
            "description": "Explicit input payload used for binding and expression resolution."
          },
          "session": {
            "type": ["object", "array", "null"],
            "description": "Optional explicit session metadata."
          },
          "state": {
            "type": ["object", "array", "null"],
            "description": "Optional explicit state override. Persistent state still uses the Greentic state store."
          },
          "interaction": {
            "type": "object",
            "required": ["interaction_type", "action_id", "card_instance_id"],
            "properties": {
              "enabled": {
                "type": "boolean"
              },
              "interaction_type": {
                "type": "string",
                "enum": ["Submit", "Execute", "OpenUrl", "ShowCard", "ToggleVisibility"]
              },
              "action_id": {
                "type": "string"
              },
              "verb": {
                "type": ["string", "null"]
              },
              "raw_inputs": {
                "type": ["object", "array", "string", "null"]
              },
              "card_instance_id": {
                "type": "string"
              },
              "metadata": {
                "type": ["object", "array", "null"]
              }
            }
          },
          "mode": {
            "type": "string",
            "enum": ["render", "validate", "renderAndValidate"],
            "default": "renderAndValidate",
            "description": "Whether to render, validate only, or both."
          },
          "validation_mode": {
            "type": "string",
            "enum": ["off", "warn", "error"],
            "default": "warn",
            "description": "Per-call override for invocation schema validation issues."
          }
        }
      },
      "output_schema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "title": "Adaptive Card result output",
        "type": "object",
        "properties": {
          "rendered_card": { "type": ["object", "array", "null"] },
          "event": { "type": ["object", "null"] },
          "state_updates": {
            "type": "array",
            "items": { "type": "object" }
          },
          "session_updates": {
            "type": "array",
            "items": { "type": "object" }
          },
          "card_features": {
            "type": "object",
            "properties": {
              "version": { "type": ["string", "null"] },
              "used_elements": { "type": "array", "items": { "type": "string" } },
              "used_actions": { "type": "array", "items": { "type": "string" } },
              "uses_show_card": { "type": "boolean" },
              "uses_toggle_visibility": { "type": "boolean" },
              "uses_media": { "type": "boolean" },
              "uses_auth": { "type": "boolean" },
              "requires_features": { "type": ["object", "array", "null"] }
            }
          },
          "validation_issues": {
            "type": "array",
            "items": { "type": "object" }
          },
          "telemetry_events": {
            "type": "array",
            "items": { "type": "object" }
          }
        }
      }
    }
  ],
  "profiles": {
    "default": "stateless",
    "supported": ["stateless"]
  },
  "supports": ["messaging"],
  "version": "0.1.20",
  "world": "greentic:component/component-v0-v6-v0@0.6.0"
}
