                  "prompt": "Deprecated alias for locale retained for compatibility.",
                  "type": "string"
                },
                {
                  "id": "interaction",
                  "prompt": "Interaction:",
                  "type": "string"
                },
                {
                  "id": "locale",
                  "prompt": "Preferred locale for this render. Overrides session and envelope locale when valid.",
                  "type": "string"
                },
                {
                  "default": "renderAndValidate",
                  "id": "mode",
                  "options": [
                    "render",
                    "validate",
                    "renderAndValidate"
                  ],
                  "prompt": "Whether to render, validate only, or both.",
                  "type": "enum"
                },
                {
                  "id": "node_id",
                  "prompt": "Optional node id used to scope persisted state and helper context.",
                  "type": "string"
                },
                {
                  "id": "payload",
                  "prompt": "Explicit input payload used for binding and expression resolution.",
                  "type": "string"
                },
                {
                  "id": "session",
                  "prompt": "Optional explicit session metadata.",
                  "type": "string"
                },
                {
                  "id": "state",
                  "prompt": "Optional explicit state override. Persistent state still uses the Greentic state store.",
                  "type": "string"
                },
                {
                  "default": "warn",
                  "id": "validation_mode",
                  "options": [
                    "off",
                    "warn",
                    "error"
                  ],
                  "prompt": "Per-call override for invocation schema validation issues.",
                  "type": "enum"
                }
              ]
            },
            "routing": [
              {
                "to": "emit_config"
              }
            ]
